generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String
  role           String    @default("admin")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  activities Activity[]
  settings   Setting[]
  sessions   Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id               String   @id @default(cuid())
  title            String
  description      String?
  price            Float
  compareAtPrice   Float?
  status           String   @default("draft") // draft | ready | published | error
  category         String?
  variants         String   @default("[]") // JSON array
  images           String   @default("[]") // JSON array of URLs
  source           String   @default("kalodata.com")
  kaloSourceUrl    String?
  shopifyProductId String?
  syncedAt         DateTime?
  aiGenerated      Boolean  @default(false)
  aiTitle          String?
  aiDescription    String?
  aiBullets        String?  // JSON array
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  importJobId    String?
  importJob      ImportJob?    @relation(fields: [importJobId], references: [id])
  themePresetId  String?
  themePreset    ThemePreset?  @relation(fields: [themePresetId], references: [id])
  reviews        Review[]
  launchProjects LaunchProject[]
}

model ImportJob {
  id               String    @id @default(cuid())
  source           String    @default("Kalo Data")
  url              String
  status           String    @default("queued") // queued | running | completed | failed
  productsFound    Int       @default(0)
  productsImported Int       @default(0)
  errors           Int       @default(0)
  errorLog         String?   // JSON array of error messages
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?

  products Product[]
}

model Activity {
  id        String   @id @default(cuid())
  type      String   // import | publish | ai | error | sync
  message   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Setting {
  id     String @id @default(cuid())
  key    String
  value  String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, userId])
}

model ThemePreset {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String
  isDefault   Boolean  @default(false)
  colors      String   // JSON: { accent, background, buttonBg, buttonText, badgeBg }
  typography  String   // JSON: { headingFont, bodyFont, headingScale, bodyScale }
  sections    String   // JSON: ordered array of section configs for product template
  badges      String   // JSON: [{ text, color, icon }]
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products       Product[]
  launchProjects LaunchProject[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  author    String?
  rating    Int
  text      String
  date      String?
  verified  Boolean  @default(false)
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
}

model LaunchProject {
  id               String    @id @default(cuid())
  name             String
  kaloUrl          String
  status           String    @default("importing") // importing | analyzing | pricing | copywriting | building | ready | error
  currentStep      Int       @default(1)

  // Step 1: Import
  productId        String?
  product          Product?  @relation(fields: [productId], references: [id])
  rawProductData   String?   // JSON: full scraped payload

  // Step 2: Ad Intelligence
  adData           String?   // JSON: user-pasted ad info
  adAnalysis       String?   // JSON: AI analysis result

  // Step 3: Pricing
  competitorData   String?   // JSON: scraped competitor prices
  pricingResult    String?   // JSON: recommended tiers

  // Step 4: Copy
  websiteCopy      String?   // JSON: AI-generated website copy
  adCopy           String?   // JSON: recommended ad copy

  // Step 5: Theme
  themePresetId    String?
  themePreset      ThemePreset? @relation(fields: [themePresetId], references: [id])
  themeZipPath     String?

  errorLog         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
